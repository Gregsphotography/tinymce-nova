{
  "name": "@greg/tinymce-nova",
  "version": "1.0.0",
  "description": "A Laravel Nova field that integrates TinyMCE editor with your local TinyMCE installation.",
  "keywords": [
    "laravel",
    "nova",
    "tinymce",
    "editor",
    "wysiwyg"
  ],
  "license": "MIT",
  "private": false,
  "scripts": {
    "dev": "npm run development",
    "development": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "prod": "npm run production",
    "production": "mix --production"
  },
  "devDependencies": {
    "laravel-mix": "^6.0.49",
    "lodash": "^4.17.21",
    "postcss": "^8.4.31",
    "vue-loader": "^17.0.0",
    "@vue/compiler-sfc": "^3.3.0"
  },
  "dependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/gregsphotography/tinymce-nova.git"
  },
  "bugs": {
    "url": "https://github.com/gregsphotography/tinymce-nova/issues"
  },
  "homepage": "https://github.com/gregsphotography/tinymce-nova#readme"
}